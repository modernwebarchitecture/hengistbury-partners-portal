---
export const prerender = false;
import LoginForm from '../../components/LoginForm';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Investor Login | Hengistbury Investment Partners</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <div class="login-page">
    <div class="login-left">
      <div class="login-brand">
        <a href="/" class="logo">
          <span class="logo-h">H</span>engistbury
        </a>
        <p class="brand-tagline">Investment Partners</p>
      </div>
      <div class="brand-footer">
        <p>Authorised and regulated by the<br/>Financial Conduct Authority</p>
        <p style="margin-top:0.5rem;font-size:0.75rem;opacity:0.5;">OC365747</p>
      </div>
    </div>

    <div class="login-right">
      <div class="login-box">
        <div class="login-head">
          <h1>Investor Portal</h1>
          <p>Sign in to access your investor documents and portfolio updates.</p>
        </div>

        <LoginForm client:load />

        <div class="login-footer">
          <a href="/" class="back-link">← Return to public site</a>
          <p>
            Having trouble?
            <a href="/contact">Contact us</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', system-ui, sans-serif; }

  .login-page {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    min-height: 100vh;
  }

  .login-left {
    background: #0f1d2f;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 3rem;
    position: relative;
    overflow: hidden;
  }

  .login-left::before {
    content: '';
    position: absolute;
    width: 400px;
    height: 400px;
    border: 1px solid rgba(201,168,76,0.1);
    border-radius: 50%;
    bottom: -100px;
    right: -100px;
  }

  .login-left::after {
    content: '';
    position: absolute;
    width: 250px;
    height: 250px;
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 50%;
    bottom: -30px;
    right: -30px;
  }

  .logo {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.8rem;
    color: #fff;
    text-decoration: none;
  }

  .logo-h { color: #c9a84c; }

  .brand-tagline {
    color: rgba(255,255,255,0.45);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-top: 0.25rem;
  }

  .brand-footer {
    color: rgba(255,255,255,0.4);
    font-size: 0.8rem;
    line-height: 1.6;
  }

  .login-right {
    background: #1a2f47;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .login-box {
    width: 100%;
    max-width: 400px;
  }

  .login-head {
    margin-bottom: 2rem;
  }

  .login-head h1 {
    font-family: 'EB Garamond', serif;
    font-size: 2rem;
    font-weight: 400;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .login-head p {
    color: rgba(255,255,255,0.55);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .login-footer {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .back-link,
  .login-footer p,
  .login-footer a {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-link:hover,
  .login-footer a:hover {
    color: #c9a84c;
  }

  @media (max-width: 768px) {
    .login-page { grid-template-columns: 1fr; }
    .login-left { padding: 2rem; min-height: 160px; }
    .login-right { padding: 2rem; }
  }
</style>
